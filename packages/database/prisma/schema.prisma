// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int       @id @default(autoincrement())
  username String
  email    String    @unique
  password String?
  accounts Account[]
}

model Account {
  id     Int @id @default(autoincrement())
  userId Int

  provider          String
  providerAccountId String

  accessToken  String?
  refreshToken String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model InterviewSession {
  id          Int      @id @default(autoincrement())
  userId      String
  role        String
  difficulty  String
  status      String   @default("active") // "active" | "completed"
  currentQues Int      @default(0) // 0 = intro stage, 1-10 = questions
  createdAt   DateTime @default(now())

  questions InterviewQuestion[]
  report    InterviewReport?
}

model InterviewQuestion {
  id        Int              @id @default(autoincrement())
  sessionId Int
  session   InterviewSession @relation(fields: [sessionId], references: [id])
  question  String           @db.Text
  answer    String?          @db.Text
  score     Int?
  feedback  String?          @db.Text
  order     Int // 0 = intro, 1-10 = actual questions
  createdAt DateTime         @default(now())

  @@unique([sessionId, order])
}

model InterviewReport {
  id            Int              @id @default(autoincrement())
  sessionId     Int              @unique
  session       InterviewSession @relation(fields: [sessionId], references: [id])
  overallScore  Int
  communication Int
  technical     Int // fixed typo: "tecnical" → "technical"
  confidence    Int
  summary       String           @db.Text
  improvements  String           @db.Text
  createdAt     DateTime         @default(now())
}

// Jobs Schema 

enum jobType {
  full_time
  part_time
  contract
  internship
  other
}

enum JobCategory {
  startup
  faang
  company
  hft
  other
}

model Job {
  id String @id @default(uuid())

  externalId String? @unique
  source     String

  title         String
  company       String
  companyLetter String
  location      String

  salary    Int?
  salaryMin Int?
  salaryMax Int?

  type     jobType
  category JobCategory

  description String
  skills      String[]

  applyUrl String

  postedAt DateTime

  isVerified Boolean @default(false)
  isSaved    Boolean @default(false)

  createdAt DateTime @default(now())
}

// DSA Schema

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id             String           @id @default(uuid())
  lcId           Int              @unique
  title          String
  difficulty     Difficulty
  topic          String?
  acceptanceRate Float?
  leetcodeUrl    String
  createdAt      DateTime         @default(now())
  companies      ProblemCompany[]
}

model Company {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  domain    String?
  logoUrl   String?
  createdAt DateTime         @default(now())
  problems  ProblemCompany[]
}

model ProblemCompany {
  id         String   @id @default(uuid())
  frequency  Int?
  timeWindow String?
  source     String?
  createdAt  DateTime @default(now())

  problemId String
  companyId String

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([problemId, companyId, timeWindow])
  @@index([problemId])
  @@index([companyId])
}
